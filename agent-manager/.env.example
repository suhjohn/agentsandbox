PORT=3132
DATABASE_URL=postgres://postgres:password@localhost:5679/agent_manager
# Required secrets (32+ chars each)
USER_JWT_SECRET=replace-with-32-plus-char-secret
SANDBOX_SIGNING_SECRET=replace-with-32-plus-char-secret
SANDBOX_TOKEN_ENCRYPTION_SECRET=replace-with-32-plus-char-secret
AGENT_MANAGER_API_KEY=replace-with-non-empty-api-key
JWT_EXPIRES_IN=7d
ALLOWED_DOMAINS=company.com
OPENAI_API_KEY=

# Public base image for Modal builds (must be linux/amd64)
AGENT_BASE_IMAGE_REF=ghcr.io/your-user-or-org/agent:latest

# Session sandbox lifetime tuning (Modal)
# Stop sandboxes after this many ms of inactivity (default: 10 minutes).
SESSION_SANDBOX_IDLE_TIMEOUT_MS=600000

# GitHub OAuth (optional)
# Create a GitHub OAuth App and set:
# - Authorization callback URL: http://localhost:3132/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URL=http://localhost:3132/auth/github/callback
GITHUB_OAUTH_ALLOWED_ORIGINS=http://localhost:5173

# Static file storage for uploaded/profile avatars
# Leave STATIC_FILES_S3_BUCKET unset in local development to store files under STATIC_FILES_LOCAL_DIR.
STATIC_FILES_S3_ENDPOINT=
STATIC_FILES_S3_REGION=us-east-1
STATIC_FILES_S3_BUCKET=
STATIC_FILES_S3_ACCESS_KEY_ID=
STATIC_FILES_S3_SECRET_ACCESS_KEY=
STATIC_FILES_S3_FORCE_PATH_STYLE=true
STATIC_FILES_LOCAL_DIR=.data/static-files
