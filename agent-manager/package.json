{
  "name": "@agent/manager",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "bun test --runInBand",
    "test:integration": "bun run scripts/run-integration-tests.ts",
    "test:modal:bash-echo": "bun run src/coordinator/testAgent.ts --dry-run",
    "test:modal:service-reads": "bun run src/coordinator/testAgent.ts",
    "openapi": "bun run scripts/generate-openapi.ts",
    "openapi:generate": "bun run scripts/generate-openapi.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@ai-sdk/google": "^3.0.30",
    "@ai-sdk/openai": "^3.0.30",
    "@hono/zod-validator": "^0.7.6",
    "@mariozechner/pi-coding-agent": "^0.52.12",
    "ai": "^6.0.94",
    "bash-tool": "^1.3.14",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.4",
    "just-bash": "^2.10.0",
    "modal": "^0.6.3",
    "postgres": "^3.4.5",
    "redis": "^5.10.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.0",
    "@types/bun": "latest",
    "drizzle-kit": "^0.30.4",
    "openapi3-ts": "^4.5.0",
    "typescript": "^5.3.0"
  }
}
